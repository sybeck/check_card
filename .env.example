# 실제 값은 .env 에 채워 넣으세요. (.env 는 git에 커밋하지 마세요)

# ===== Slack =====
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# ===== Meta Ads =====
META_API_VERSION=v24.0
META_BRAINOLOGY_ACCESS_TOKEN=
META_BRAINOLOGY_AD_ACCOUNT_ID=
META_BURDENZERO_ACCESS_TOKEN=
META_BURDENZERO_AD_ACCOUNT_ID=
BRAINOLOGY_PRODUCT_NAMES=뉴턴젤리,오메가3
# BRAINOLOGY_PRODUCT_ALIASES_뉴턴젤리=
# BRAINOLOGY_PRODUCT_ALIASES_오메가3=

# ===== Google Sheets (광고소재 raw 누적) =====
# 서비스 계정 JSON 키 파일의 절대경로
GOOGLE_SERVICE_ACCOUNT_JSON=C:\path\to\service_account.json
# 대상 스프레드시트 ID 또는 전체 URL (시트를 서비스 계정 client_email 에 '편집자'로 공유 필요)
META_CREATIVE_SHEET_ID=
# 데이터를 쌓을 탭(워크시트) 이름 (없으면 자동 생성)
META_CREATIVE_WORKSHEET=creative_raw

# ===== Notion (Meta 광고 성과 개인별 집계 기록) =====
# notion.so/my-integrations 에서 발급한 내부 통합 토큰. 대상 DB를 이 통합에 연결(공유)해야 함.
NOTION_TOKEN=
# 성과를 기록할 데이터베이스 ID 또는 URL
NOTION_PERFORMANCE_DB_ID=37f7b6aa8429807bae8fdaa5da90e19b

# ===== 팝빌 (현금영수증 / 전자세금계산서 발행) =====
# 팝빌(POPBiLL) 연동신청 승인 후 발급되는 값
POPBILL_LINK_ID=
POPBILL_SECRET_KEY=
# true 면 팝빌 테스트베드, false(기본)면 운영(실제 국세청 신고)
POPBILL_IS_TEST=false
# 공급자(우리 회사) 사업자번호 10자리 (하이픈 없이)
POPBILL_CORP_NUM=
# --- 세금계산서 공급자(발행자) 고정정보 ---
POPBILL_INVOICER_CORP_NAME=    # 상호
POPBILL_INVOICER_CEO_NAME=     # 대표자 성명
POPBILL_INVOICER_ADDR=         # 주소
POPBILL_INVOICER_BIZ_TYPE=     # 업태
POPBILL_INVOICER_BIZ_ITEM=     # 종목
POPBILL_INVOICER_CONTACT_NAME= # 담당자명
POPBILL_INVOICER_TEL=          # 연락처
POPBILL_INVOICER_EMAIL=        # 발행 담당자 이메일
