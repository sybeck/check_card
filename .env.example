# 실제 값은 .env 에 채워 넣으세요. (.env 는 git에 커밋하지 마세요)

# ===== Slack =====
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# ===== Meta Ads =====
META_API_VERSION=v24.0
META_BRAINOLOGY_ACCESS_TOKEN=
META_BRAINOLOGY_AD_ACCOUNT_ID=
META_BURDENZERO_ACCESS_TOKEN=
META_BURDENZERO_AD_ACCOUNT_ID=
BRAINOLOGY_PRODUCT_NAMES=뉴턴젤리,오메가3
# BRAINOLOGY_PRODUCT_ALIASES_뉴턴젤리=
# BRAINOLOGY_PRODUCT_ALIASES_오메가3=

# ===== Google Sheets (광고소재 raw 누적) =====
# 서비스 계정 JSON 키 파일의 절대경로
GOOGLE_SERVICE_ACCOUNT_JSON=C:\path\to\service_account.json
# 대상 스프레드시트 ID 또는 전체 URL (시트를 서비스 계정 client_email 에 '편집자'로 공유 필요)
META_CREATIVE_SHEET_ID=
# 데이터를 쌓을 탭(워크시트) 이름 (없으면 자동 생성)
META_CREATIVE_WORKSHEET=creative_raw
